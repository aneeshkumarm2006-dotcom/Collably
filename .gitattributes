# Normalize line endings to LF in the repo for cross-platform consistency
# (devs on Windows/macOS, CI + EAS cloud builds on Linux).
* text=auto eol=lf

# Scripts that must stay LF even on Windows checkouts
*.sh text eol=lf

# Binary assets — never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.aab binary
*.ipa binary
*.jks binary
*.keystore binary
