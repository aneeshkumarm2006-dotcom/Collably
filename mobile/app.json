{
  "expo": {
    "name": "Collably",
    "slug": "collably",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "collably",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.collably.app",
      "associatedDomains": ["applinks:collably.app"]
    },
    "android": {
      "package": "com.collably.app",
      "adaptiveIcon": {
        "backgroundColor": "#0C831F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            { "scheme": "https", "host": "collably.app", "pathPrefix": "/reset-password" },
            { "scheme": "https", "host": "collably.app", "pathPrefix": "/campaign" }
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8CB46",
          "image": "./assets/images/splash-icon-ink.png",
          "imageWidth": 96,
          "dark": {
            "backgroundColor": "#F1BE26",
            "image": "./assets/images/splash-icon-ink.png",
            "imageWidth": 96
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Collably needs access to your photos so you can upload a profile picture, business logo, campaign cover, and content proof.",
          "cameraPermission": "Collably needs camera access so you can take photos for your profile and content submissions."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0C831F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
