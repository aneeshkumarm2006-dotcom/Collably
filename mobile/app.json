{
  "expo": {
    "name": "CollabSpace",
    "slug": "collably",
    "version": "0.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "collably",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.collably.app",
      "associatedDomains": [
        "applinks:collably.app"
      ]
    },
    "android": {
      "package": "com.collably.app",
      "adaptiveIcon": {
        "backgroundColor": "#1877F2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "collably.app",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "https",
              "host": "collably.app",
              "pathPrefix": "/campaign"
            }
          ]
        }
      ],
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1877F2",
          "image": "./assets/images/splash-icon-ink.png",
          "imageWidth": 96,
          "dark": {
            "backgroundColor": "#0866FF",
            "image": "./assets/images/splash-icon-ink.png",
            "imageWidth": 96
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "CollabSpace needs access to your photos so you can upload a profile picture, business logo, campaign cover, and content proof.",
          "cameraPermission": "CollabSpace needs camera access so you can take photos for your profile and content submissions."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#1877F2"
        }
      ]
    ],
    "updates": {
      "enabled": false
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a7e78633-34dd-4079-83e7-85cfd6b2a421"
      }
    },
    "owner": "aneeshkumarm"
  }
}
