# Collably mobile — local environment (gitignored). Created from .env.example.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle (Expo inlines them at build).
# Uncomment + fill a line to enable that feature; restart Metro after editing.

# Backend API base URL, including the /api prefix.
# Leave UNSET in dev to auto-derive your laptop's LAN IP from the Metro host
# (so Expo Go on a physical phone can reach http://<lan-ip>:4000/api).
# Set it explicitly when that auto-detection doesn't fit your network, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.5:4000/api
# For preview/production builds this is provided per-profile in eas.json instead.
# EXPO_PUBLIC_API_URL=

# Google OAuth client IDs (Phase 0 §2f — Google Cloud Console OAuth 2.0 clients).
# One client per platform. The backend verifies the id_token against EACH of
# these (set the matching GOOGLE_*_CLIENT_ID server-side too). The iOS client ID
# also drives the native redirect URL scheme that app.config.js embeds, so iOS
# sign-in needs it set AND a NEW dev/EAS build (not Expo Go) to take effect.
# Leave all UNSET to hide the "Continue with Google" button until created.
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=<number>-<hash>.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=<number>-<hash>.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=<number>-<hash>.apps.googleusercontent.com

# Google Maps SDK keys (On-Site Location feature). Read by app.config.js (embeds
# them in the native build) AND by lib/env (MAPS_ENABLED). One key per platform
# because a Google API key can hold only ONE app restriction (Android OR iOS).
# Maps SDK keys are not secret — lock them by app package/bundle + SHA-1 in Google
# Cloud. Leave UNSET and every map shows "Map coming soon"; set them + run a NEW
# dev build to enable. (react-native-maps does NOT run in Expo Go.)
# EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=AIza<android-app-restricted-key>
# EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=AIza<ios-app-restricted-key>

# NOTE: the Geocoding key is BACKEND-ONLY (server env / Render) — it's already set
# there. Do NOT put it in this mobile .env: every EXPO_PUBLIC_* var is inlined into
# the shipped app bundle, which would expose an unrestricted server-side key.

# TESTING ONLY — skip the mandatory email/phone verification gate so the rest of
# the app is reachable before SMS/email delivery is fully set up. Works ONLY in dev
# builds; production always enforces verification (the flag is ignored when
# __DEV__ is false). Set to false (and restart Metro) to test verification itself.
# EXPO_PUBLIC_SKIP_VERIFY=true

# Require phone (SMS) verification at signup. Off by default → email-only signup,
# which is what the first Play Store build ships (SMS to India needs Twilio DLT
# we don't have yet). Set true at build time to bring the phone step back once SMS
# delivery is production-ready. The phone screens and backend routes stay intact.
# EXPO_PUBLIC_REQUIRE_PHONE=true