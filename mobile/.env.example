# Collably mobile — environment template. Copy to `.env` (gitignored) for local dev.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle (Expo inlines them at build).

# Backend API base URL, including the /api prefix.
# Leave UNSET in dev to auto-derive your laptop's LAN IP from the Metro host
# (so Expo Go on a physical phone can reach http://<lan-ip>:4000/api).
# Set it explicitly when that auto-detection doesn't fit your network, e.g.:
#   EXPO_PUBLIC_API_URL=http://192.168.1.5:4000/api
# For preview/production builds this is provided per-profile in eas.json instead.
# EXPO_PUBLIC_API_URL=

# Google OAuth client IDs (Phase 0 §2f — Google Cloud Console OAuth 2.0 clients).
# One client per platform; the web client is the id_token audience the backend
# verifies. Leave UNSET to hide the "Continue with Google" button until created.
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
