# Collably admin dashboard — environment template.
# Copy to `.env.local` and fill in real values (`.env.local` is gitignored).

# The single hardcoded password the admin types on the login screen.
ADMIN_DASHBOARD_PASSWORD=change-me-to-a-strong-password

# Secret used to sign the session cookie (any long random string).
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string

# Where the Collably Express backend is reachable from this server.
BACKEND_API_URL=http://localhost:4000

# Must match ADMIN_API_KEY in the backend's .env — used for server-to-server
# auth against /api/admin/*.
ADMIN_API_KEY=change-me-to-match-the-backend-ADMIN_API_KEY
