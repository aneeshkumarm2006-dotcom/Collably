# Collably backend — environment template.
# Copy to `.env` and fill in real values (`.env` is gitignored).
# Real secrets live in _ai_context/Phase 0 — Setup/credentials.local.md

# --- Server ---
PORT=4000
# Comma-separated list of allowed origins for CORS. "*" allows all (dev only).
# The Collably website talks to this backend SERVER-SIDE (Next.js route handlers
# /SSR proxy → backend), so the browser never calls the backend cross-origin and
# the website's origin does NOT strictly need to be listed here. Add it only if a
# browser will ever hit the API directly (e.g. http://localhost:3001 in dev,
# https://app.collably.app in prod). When you set an explicit allowlist (not "*"),
# the server also enables credentials.
CORS_ORIGIN=*
NODE_ENV=development
# Public base URL of the Collably website (no trailing slash). When set,
# password-reset emails link to the web reset route (<WEB_APP_URL>/reset-password/
# <token>) instead of the mobile collably:// deep link. Leave blank pre-launch.
WEB_APP_URL=

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
# Access-token lifetime (e.g. "15m", "1h", "7d").
JWT_EXPIRES_IN=7d
# Refresh tokens: separate secret + longer lifetime. If JWT_REFRESH_SECRET is
# left blank, the server derives one from JWT_SECRET (fine for dev; set it in prod).
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=30d
# How long a password-reset link stays valid (minutes).
PASSWORD_RESET_TTL_MINUTES=60

# --- Database: MongoDB Atlas (Phase 0 §2a) ---
MONGODB_URI=mongodb://127.0.0.1:27017/collably

# --- Image storage: Cloudinary (Phase 0 §2b) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Email: Resend (transactional email: OTP, password reset, notifications) ---
#   1. Create an API key at resend.com > API Keys → RESEND_API_KEY.
#   2. Add + verify your sending domain (resend.com > Domains): add the SPF/DKIM/
#      DMARC DNS records they give you. Until the domain is verified you can only
#      send FROM onboarding@resend.dev and only TO your own account email.
#   3. RESEND_FROM must be an address on the VERIFIED domain, e.g.
#      "LocalShout <noreply@davnoot.com>".
# Free tier: 3,000/month AND 100/day. Pro ($20/mo): 50,000/month, no daily cap.
RESEND_API_KEY=
RESEND_FROM="LocalShout <noreply@davnoot.com>"

# --- SMS: Twilio (phone OTP) ---
# Without these the phone-verify flow still issues a code but sends no SMS, so
# nobody can pass the mandatory phone gate in production.
#   TWILIO_ACCOUNT_SID — starts "AC..." (Twilio Console dashboard)
#   TWILIO_AUTH_TOKEN  — the auth token next to it; rotate if ever leaked
#   TWILIO_FROM        — either a Twilio phone number in E.164 ("+1416...")
#                        OR a Messaging Service SID (starts "MG..."), auto-detected.
# NOTE: Twilio blocks SMS to most countries until you enable that country under
# Messaging > Settings > Geo permissions. A trial account can ONLY send to numbers
# you have verified in the console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- One-time codes (email + phone verification) ---
# How long a code stays valid, max failed guesses before it burns, and the
# minimum gap between resends to the same target.
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30
# Dev aid: when true AND NODE_ENV is not production, the send endpoints return the
# plain code in the response so the flow is testable without a real SMS/email
# provider. Ignored in production, so a live code can never leak to callers.
EXPOSE_DEV_OTP=false

# --- Sign in with Apple ---
# Bundle id that Apple identity tokens must be issued for (the token's `aud`).
# No Apple secret or .p8 is needed: the server verifies against Apple's PUBLIC keys.
APPLE_BUNDLE_ID=com.collably.app

# --- Push: Expo (Phase 0 §2d) ---
EXPO_ACCESS_TOKEN=

# --- Google sign-in (Phase 0 §2f) ---
# The server verifies the mobile app's Google ID token against EVERY client ID
# below. expo-auth-session stamps the per-platform client ID as the token's
# audience, so a NATIVE iOS/Android sign-in only works if its client ID is listed
# here too — the web client alone is not enough on a device build.
#   GOOGLE_CLIENT_ID         — web client (Expo web / admin / the Collably WEBSITE audience)
#   GOOGLE_IOS_CLIENT_ID     — iOS native client (optional; required for iOS)
#   GOOGLE_ANDROID_CLIENT_ID — Android native client (optional; required for Android)
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# --- Maps: Google Geocoding (On-Site Location feature) ---
# SERVER-SIDE ONLY key (address <-> lat/lng). Restrict it to the Geocoding API
# (+ your server IP) in Google Cloud. Never expose it to the mobile app — the
# Maps SDK keys are separate and live in the mobile build config instead.
# Leave blank until you have it: geocoding self-disables ("coming soon") and
# campaigns still work via manually-dropped pins.
GOOGLE_GEOCODING_API_KEY=

# --- Admin dashboard (server-to-server) ---
# Shared secret the Next.js admin dashboard (app/admin) sends as `x-admin-api-key`
# to authenticate against /api/admin/* without a JWT. Use a long random string and
# set the SAME value in app/admin/.env.local. Leave blank to disable the key path.
ADMIN_API_KEY=change-me-to-a-long-random-string
