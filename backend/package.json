{
  "name": "@collably/backend",
  "version": "0.1.0",
  "private": true,
  "description": "Collably backend — standalone Express + TypeScript REST API (MongoDB/Mongoose).",
  "main": "dist/backend/src/index.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/backend/src/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:models": "node dist/backend/src/scripts/verifyModels.js",
    "verify:auth": "node dist/backend/src/scripts/verifyAuth.js",
    "verify:services": "node dist/backend/src/scripts/verifyServices.js",
    "verify:routes": "node dist/backend/src/scripts/verifyRoutes.js",
    "seed": "node dist/backend/src/scripts/seed.js"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "typescript": "^5.9.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0"
  }
}
